generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  LANDLORD
  TENANT
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  PENDING
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  PARTIAL
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum NoticeStatus {
  DRAFT
  SENT
}

enum AgentActionType {
  RENT_REMINDER
  LATE_RENT_NOTICE
  LATE_RENT_ESCALATION
  MAINTENANCE_TRIAGE
  MAINTENANCE_BOOKING
  MAINTENANCE_ESCALATION
  MESSAGE_RESPONSE
  LEASE_RENEWAL_DRAFT
  CHARGE_DISPUTE
  LEASE_BREAK_REQUEST
  LEGAL_ESCALATION
  TENANT_COMPLAINT
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

enum AgentLogStatus {
  EXECUTED
  ESCALATED
  APPROVED
  REJECTED
  SCHEDULED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(TENANT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  landlordProfile LandlordProfile?
  tenantProfile   TenantProfile?
  sentMessages    Message[]        @relation("SentMessages")
  notifications   Notification[]

  @@map("users")
}

model LandlordProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String
  lastName    String
  phone       String?
  avatarUrl   String?
  companyName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stripeAccountId  String?
  stripeConnected  Boolean  @default(false)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties   Property[]
  notices      Notice[]
  activityLogs ActivityLog[]
  transactionLogs TransactionLog[]
  importBatches ImportBatch[]
  uploadedDocuments UploadedDocument[]
  agentConfig  AgentConfig?
  agentLogs    AgentLog[]
  vendors      Vendor[]

  @@map("landlord_profiles")
}

model TenantProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String
  lastName  String
  phone     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases               Lease[]
  payments             Payment[]
  maintenanceRequests  MaintenanceRequest[]
  notices              Notice[]
  conversationTenants  ConversationParticipant[]

  @@map("tenant_profiles")
}

model Property {
  id          String   @id @default(cuid())
  landlordId  String
  name        String
  address     String
  city        String
  state       String
  zip         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  units    Unit[]

  @@map("properties")
}

model Unit {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  floor      Int?
  bedrooms   Int      @default(1)
  bathrooms  Float    @default(1)
  sqft       Int?
  rentAmount Float
  isOccupied Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]

  @@map("units")
}

model Lease {
  id         String      @id @default(cuid())
  tenantId   String
  unitId     String
  startDate  DateTime
  endDate    DateTime
  monthlyRent Float
  deposit    Float
  status     LeaseStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant   TenantProfile @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit     Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  payments Payment[]
  notices  Notice[]

  @@map("leases")
}

model Payment {
  id                    String        @id @default(cuid())
  leaseId               String
  tenantId              String
  amount                Float
  dueDate               DateTime
  paidDate              DateTime?
  status                PaymentStatus @default(PENDING)
  description           String?
  stripeSessionId       String?
  stripePaymentIntentId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  lease           Lease          @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant          TenantProfile  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactionLogs TransactionLog[]

  @@map("payments")
}

model TransactionLog {
  id              String   @id @default(cuid())
  paymentId       String?
  leaseId         String?
  tenantId        String?
  landlordId      String?
  stripeSessionId String?
  amount          Float
  fee             Float
  currency        String   @default("cad")
  status          String
  metadata        Json?
  createdAt       DateTime @default(now())

  payment  Payment?        @relation(fields: [paymentId], references: [id])
  landlord LandlordProfile? @relation(fields: [landlordId], references: [id])

  @@map("transaction_logs")
}

model Conversation {
  id        String   @id @default(cuid())
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  tenantId       String
  createdAt      DateTime @default(now())

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant       TenantProfile @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([conversationId, tenantId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notice {
  id         String       @id @default(cuid())
  landlordId String
  tenantId   String
  leaseId    String?
  title      String
  body       String
  status     NoticeStatus @default(DRAFT)
  sentAt     DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  tenant   TenantProfile   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease    Lease?          @relation(fields: [leaseId], references: [id])

  @@map("notices")
}

model MaintenanceRequest {
  id          String              @id @default(cuid())
  tenantId    String
  unitId      String
  title       String
  description String
  status      MaintenanceStatus   @default(OPEN)
  priority    MaintenancePriority @default(MEDIUM)
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant TenantProfile @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit   Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("maintenance_requests")
}

model AgentConfig {
  id                String   @id @default(cuid())
  landlordId        String   @unique
  isEnabled         Boolean  @default(true)
  autoRentReminders Boolean  @default(true)
  autoMaintenance   Boolean  @default(true)
  autoMessages      Boolean  @default(true)
  autoLeaseRenewal  Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

model AgentLog {
  id          String          @id @default(cuid())
  landlordId  String
  actionType  AgentActionType
  confidence  ConfidenceLevel
  summary     String
  details     Json?
  entityType     String?
  entityId       String?
  status         AgentLogStatus
  scheduledAt    DateTime?
  draftContent   String?
  reminderSentAt DateTime?
  urgentAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@map("agent_logs")
}

model Vendor {
  id         String   @id @default(cuid())
  landlordId String
  name       String
  phone      String
  email      String?
  specialty  String
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  landlord LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@map("vendors")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  entityId  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(cuid())
  landlordId String
  type       String
  title      String
  description String?
  entityId   String?
  createdAt  DateTime @default(now())

  landlord LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model ImportBatch {
  id         String   @id @default(cuid())
  landlordId String
  rowCount   Int      @default(0)
  metadata   Json?
  createdAt  DateTime @default(now())

  landlord LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@map("import_batches")
}

model UploadedDocument {
  id           String   @id @default(cuid())
  landlordId   String
  originalName String
  storedName   String
  mimeType     String
  sizeBytes    Int
  extracted    Json?
  createdAt    DateTime @default(now())

  landlord LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@map("uploaded_documents")
}
