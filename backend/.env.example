DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Generate with: openssl rand -base64 48 — never reuse this placeholder as a real value.
JWT_SECRET="REPLACE_ME_GENERATE_YOUR_OWN_SECRET"
JWT_EXPIRES_IN="7d"
PORT=5000
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Frontend URL
FRONTEND_URL="http://localhost:5173"

# Anthropic (Claude AI) — get from console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
# Model + provider switch for the shared AI client (backend/src/services/ai/aiClient.js).
# Set AI_PROVIDER=mock to run Autopilot fully offline (dev/tests/demo) — no API key needed.
AI_PROVIDER="anthropic"
AI_MODEL="claude-sonnet-4-6"
AI_MAX_RETRIES="2"
# Document/image extraction (e.g. the Import page's PDF/photo ingest) can take
# 30-60s+; keep this generous rather than tuning it down.
AI_TIMEOUT_MS="60000"

# Email (SMTP) — leave blank to use console-log fallback for demo
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM='"Rentora AI" <noreply@rentora.com>'

# SMS (Autopilot maintenance intake) — set SMS_PROVIDER=twilio to send real texts.
# Leave unset (defaults to the mock provider) to run Autopilot's SMS flows fully
# offline: messages are logged to the console and written to the SmsMessage table
# instead of being sent, so the app works without any Twilio account.
SMS_PROVIDER="mock"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Test database (Jest integration tests use mocked Prisma by default; only needed
# if you wire up real-DB integration tests against a disposable database).
TEST_DATABASE_URL=""
